DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hp_career

# AI provider — pluggable. Default uses Anthropic Sonnet 4.6.
# Per-feature override is optional: AI_FETCH_PROVIDER and AI_QA_PROVIDER.
AI_PROVIDER=anthropic
# AI_FETCH_PROVIDER=google
# AI_QA_PROVIDER=openai

# Provider keys — only the configured one is required at runtime.
ANTHROPIC_API_KEY=sk-ant-xxxxx
# GOOGLE_GENERATIVE_AI_API_KEY=AIza...
# OPENAI_API_KEY=sk-...

# Better Auth — secret MUST be >= 32 chars. Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=generate-with-openssl-rand-base64-32-xxxxxxxxxx
BETTER_AUTH_URL=http://localhost:3000
# Optional: extra CSRF-trusted origins (comma-separated), e.g. Vercel previews.
# BETTER_AUTH_TRUSTED_ORIGINS=https://your-preview.vercel.app
NODE_ENV=development
